{
  "name": "codewiki",
  "version": "0.1.0",
  "description": "Markdown-first CodeWiki framework CLI with human-approved wiki proposals.",
  "type": "module",
  "bin": {
    "codewiki": "./dist/bin/codewiki.js"
  },
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "test:unit": "vitest run",
    "prepack": "npm run build"
  },
  "keywords": [
    "codewiki",
    "ai",
    "markdown",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.3"
  }
}
